// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "opencode": {
      "type": "registry"
    }
  },
  "cli_default_open_behavior": "existing_window",
  "base_keymap": "VSCode",
  "agent": {
    "default_model": {
      "provider": "opencode",
      "model": "free/minimax-m2.5-free",
      "enable_thinking": false,
    },
    "favorite_models": [
      {
        "provider": "opencode",
        "model": "free/minimax-m2.5-free",
        "enable_thinking": false,
      },
    ],
    "model_parameters": [],
  },
  "language_models": {
    "opencode": {
      "show_free_models": true,
      "show_zen_models": true,
      "show_go_models": true,
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": true,
  "icon_theme": {
    "mode": "dark",
    "light": "VSCode Icons for Zed (Dark)",
    "dark": "VSCode Icons for Zed (Dark)",
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light",
    "dark": "Gruvbox Dark",
  },
  // ── LSP ──────────────────────────────────────────────────────────────
  "lsp": {
    "bash-language-server": {
      "settings": {
        // ShellCheck wrapper that strips --external-sources to prevent
        // unbounded memory growth (upstream bug in bash-language-server 5.x).
        "shellcheckPath": "/home/zerg/.local/bin/shellcheck-wrapper",
        // Limit background analysis — don't analyse generated .devenv/ scripts.
        // See: dotfiles/zed/shellcheck-wrapper
        "globPattern": "{**/*@(.sh|.inc|.bash|.command),!**/.devenv/**}",
        "backgroundAnalysisMaxFiles": 200,
        "includeAllWorkspaceSymbols": false,
      },
    },
    "nil": {
      "binary": {
        // nil установлен через home-manager, но FHS-окружение zed-editor-fhs
        // не видит ~/.nix-profile/bin — указываем явно.
        "path": "/home/zerg/.nix-profile/bin/nil"
      }
    },
    "nixd": {
      "disabled": true,
    },
  },
  // ── Language-Specific ─────────────────────────────────────────────────
  "languages": {
    "Nix": {
      "language_servers": ["nil", "..."],
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "nixfmt"
        }
      }
    }
  }
}
