{
  "$schema": "https://raw.githubusercontent.com/can1357/oh-my-pi/main/packages/coding-agent/src/config/mcp-schema.json",
  "mcpServers": {
    "duckduckgo": {
      "command": "node",
      "args": ["${HOME}/nixos-conf/dotfiles/.omp/ddg-mcp-server.mjs"]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "!cat ${HOME}/.config/context7/apikey"
      }
    }
  }
}
