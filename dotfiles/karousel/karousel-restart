#!/usr/bin/env bash
set -euo pipefail

# Resolve karousel script path — works with nix-profile and system-wide installs
KAROUSEL_SCRIPT="$(find -L "/run/current-system/sw/share/kwin/scripts/karousel" -name "main.js" -type f 2>/dev/null | head -1)"
if [ -z "$KAROUSEL_SCRIPT" ]; then
  KAROUSEL_SCRIPT="$(find "${HOME}/.nix-profile/share/kwin/scripts/karousel" -name "main.js" -type f 2>/dev/null | head -1)"
fi

if [ -z "$KAROUSEL_SCRIPT" ]; then
  echo "karousel: main.js not found, is the package installed?" >&2
  exit 1
fi

qdbus org.kde.KWin /Scripting unloadScript "karousel" 2>/dev/null || true
sleep 0.15
qdbus org.kde.KWin /Scripting loadScript "$KAROUSEL_SCRIPT" "karousel" 2>/dev/null || true
